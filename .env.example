# Arclight deployment config — TEMPLATE ONLY.
# Copy to .env (which is gitignored) and fill in. NEVER put a private key in here.
# The deployer key lives in a Foundry encrypted keystore, not in this file.

# --- RPC ---
# Optional. Leave unset to use Arc's public testnet RPC (foundry.toml has the fallback).
# Set this only if you switch to a keyed provider; then the key stays in .env, not in git.
# ARC_TESTNET_RPC_URL=https://your-keyed-rpc-provider/...

# --- Deploy parameters (these are PUBLIC addresses, not secrets) ---
# The off-chain metering signer's ADDRESS (its private key stays in your attestor service).
# Defaults to the deployer if unset.
ATTESTOR=0x0000000000000000000000000000000000000000

# The final owner of RevenuePool and ProofOfView. Defaults to the deployer if unset.
OWNER=0x0000000000000000000000000000000000000000

# Set to true to also deploy and enable the ZK proof-of-view privacy layer.
ENABLE_ZK=false
