# Arclight backend — TEMPLATE ONLY. Copy to .env.local (gitignored) and fill in.
# NEVER commit real private keys. These are throwaway TESTNET keys generated by `pnpm setup`.

# The advertiser agent that holds USDC in the Circle Gateway balance and pays creators per view.
AGENT_PRIVATE_KEY=0x

# The creator that receives nanopayments (the x402 seller). Address is what the agent pays to.
CREATOR_ADDRESS=0x

# Optional: the creator's private key, so the same wallet can later convert/yield/bridge its
# earnings in the demo. Not needed just to receive nanopayments.
CREATOR_PRIVATE_KEY=0x

# The off-chain metering attestor. Its ADDRESS must be set as the on-chain ProofOfView attestor
# (oracle.setAttestor) so the attestations it signs are trusted. Private key stays here only.
ATTESTOR_PRIVATE_KEY=0x

# Per-view price charged by the creator endpoint (USDC, x402 string form).
VIEW_PRICE=$0.01

# Port the backend listens on (the agent also calls its own creator endpoint here).
PORT=8787

# Optional: override the public RPC.
# ARC_TESTNET_RPC_URL=
